# .env.example — コピーして .env を作り、値を埋める（.env は gitignore 対象）
#   cp .env.example .env

# 案件台帳スプレッドシートの ID（v0-A でシート作成後に記入）
SHEET_ID=

# 対象の SES 専用 Gmail アドレス（明示用・任意）
GMAIL_ADDRESS=

# Google OAuth の JSON ファイルのパス（形式は JSON。secrets/ に置く）
GOOGLE_CREDENTIALS=./secrets/credentials.json
GOOGLE_TOKEN=./secrets/token.json

# 【Routine実行時のみ】サービスアカウント鍵のパス。設定するとユーザーOAuthフローより優先される
# GOOGLE_SERVICE_ACCOUNT_KEY=./secrets/service_account.json

# _state/_runlog の owner識別子（任意・上書き用）。未指定なら getuser()@hostname() を使う
# RUN_BY=

# 【backlog】無人化（claude -p / API）時のみ必要。v0 では不要（Claude は Claude Code 経由）
# ANTHROPIC_API_KEY=
